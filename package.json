{
  "name": "microservice-boilerplate",
  "version": "0.1.0",
  "description": "Production-Ready TypeScript Microservice Boilerplate - Clean Architecture Template",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:otel": "tsx watch --import ./src/instrumentation.ts src/index.ts",
    "build": "tsc && tsc knexfile.ts --outDir dist --module NodeNext --moduleResolution NodeNext --esModuleInterop && copyfiles -u 1 \"src/grpc/protos/**/*\" dist/",
    "start": "node dist/index.js",
    "start:otel": "node --import ./dist/instrumentation.js dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts",
    "migrate:prod": "node node_modules/.bin/knex migrate:latest --knexfile dist/knexfile.js",
    "migrate:rollback:prod": "node node_modules/.bin/knex migrate:rollback --knexfile dist/knexfile.js",
    "migrate:make": "tsx scripts/make-migration.ts",
    "seed": "tsx node_modules/.bin/knex seed:run --knexfile knexfile.ts",
    "seed:make": "tsx node_modules/.bin/knex seed:make --knexfile knexfile.ts -x ts",
    "prepare": "husky"
  },
  "keywords": [
    "microservice",
    "clean-architecture",
    "typescript",
    "fastify",
    "grpc",
    "production-ready",
    "boilerplate"
  ],
  "author": "berkeerdo (https://github.com/berkeerdo)",
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/under-pressure": "^9.0.3",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.211.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "amqp-resilient": "^1.2.0",
    "awilix": "^12.1.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.4",
    "grpc-resilient": "^1.1.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "node-caching-mysql-connector-with-redis": "^2.7.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.13",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
