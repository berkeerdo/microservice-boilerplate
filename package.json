{
  "name": "microservice-boilerplate",
  "version": "0.1.0",
  "description": "Production-Ready TypeScript Microservice Boilerplate - Clean Architecture Template",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrumentation.ts src/index.ts",
    "build": "tsc && copyfiles -u 1 \"src/grpc/protos/**/*\" dist/",
    "start": "node --import ./dist/instrumentation.js dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "db-bridge migrate up",
    "migrate:rollback": "db-bridge migrate down",
    "migrate:status": "db-bridge migrate status",
    "migrate:make": "db-bridge migrate create",
    "seed": "db-bridge seed run",
    "seed:make": "db-bridge seed create",
    "db:types": "db-bridge generate:types",
    "prepare": "husky"
  },
  "keywords": [
    "microservice",
    "clean-architecture",
    "typescript",
    "fastify",
    "grpc",
    "production-ready",
    "boilerplate"
  ],
  "author": "berkeerdo (https://github.com/berkeerdo)",
  "license": "MIT",
  "dependencies": {
    "@db-bridge/core": "^1.2.0",
    "@db-bridge/mysql": "^1.2.0",
    "@db-bridge/redis": "^1.2.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.2.0",
    "@fastify/otel": "^0.20.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/under-pressure": "^9.0.3",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@sentry/node": "^10.66.0",
    "@sentry/opentelemetry": "^10.66.0",
    "@sentry/profiling-node": "^10.66.0",
    "amqp-resilient": "^1.2.0",
    "awilix": "^13.0.5",
    "db-bridge": "^1.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "grpc-resilient": "^1.1.1",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.1",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.11 <27"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
